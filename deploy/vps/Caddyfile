# Caddy reverse proxy for the optional Maverick web dashboard.
#
# Replace `maverick.example.com` with your domain. Caddy will obtain
# and renew a Let's Encrypt cert automatically.
#
# Place at /etc/caddy/Caddyfile and reload:  caddy reload

# Global server hardening — belt-and-suspenders against the "HTTP/2 Bomb"
# class of header-amplification DoS. max_header_size caps total request-
# header bytes, so a flood of 1-byte HPACK-indexed header references can't
# balloon into a large server-side allocation; the timeouts bound how long
# a client may take to send headers or sit idle, so a stalled connection
# can't pin that memory. We deliberately do NOT set a write timeout: the
# dashboard streams responses over SSE and a write deadline would sever
# those long-lived streams.
{
    servers {
        max_header_size 64KB
        timeouts {
            read_header 15s
            read_body   1m
            idle        2m
        }
    }
}

maverick.example.com {
    # Health check passthrough.
    handle /healthz {
        respond "ok" 200
    }

    # Dashboard (when shipped).
    handle {
        reverse_proxy localhost:8765
    }

    # Basic security headers.
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
    }

    log {
        output file /var/log/caddy/maverick.log
        format json
    }
}
