# Maverick demo environment — copy to demo.env and fill in.
#   cp demo.env.example demo.env
#
# demo.env is git-ignored by convention; never commit a real key.

# REQUIRED to do anything useful: the agent makes real Anthropic API calls,
# billed to this key. Leave blank and the dashboard still boots (you can click
# around the UI) but goals will fail with a "no provider key" error.
ANTHROPIC_API_KEY=

# Host port the demo is published on (the in-container port is always 8765).
MAVERICK_DEMO_PORT=8765

# --- cost + abuse guardrails (sensible demo defaults; tune as needed) --------
# Per-goal spend cap in USD. A demo goal that loops will stop at this much.
MAVERICK_BUDGET_DOLLARS=0.50
# Goal submissions per minute (per caller, then global) before HTTP 429.
MAVERICK_DASHBOARD_MAX_GOALS_PER_MIN=3
MAVERICK_DASHBOARD_MAX_GOALS_GLOBAL_PER_MIN=10

# MAVERICK_DASHBOARD_TOKEN is generated for you by run-demo.sh and stored in
# deploy/demo/.demo-token. Set it here only if you want a fixed token.
# MAVERICK_DASHBOARD_TOKEN=
