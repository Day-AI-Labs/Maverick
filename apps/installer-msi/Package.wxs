<?xml version="1.0" encoding="utf-8"?>
<!--
  Maverick CLI - WiX Toolset v4 authoring.

  Build (Windows host with WiX v4, see build.ps1):
    .\build.ps1 -Wheel ..\..\dist\maverick_agent-0.1.6-py3-none-any.whl

  What this MSI does:
    * Installs per user (no UAC prompt) under %LOCALAPPDATA%\Programs\Maverick.
    * Ships the maverick-agent wheel + a maverick.cmd launcher and puts the
      bin\ directory on the *user* PATH.
    * maverick.cmd resolves the pip console script (maverick.cli:main); on
      first run it pip-installs the bundled wheel into the per-user site.
      (`py -m maverick` does NOT work - the package has no __main__.py - so
      the launcher goes through the console-script entry point instead.)

  The produced MSI ships UNSIGNED - same posture as the Tauri desktop
  installer (apps/installer-desktop): SmartScreen will warn until a Windows
  code-signing certificate exists.

  Preprocessor variables (-d on the wix command line):
    ProductVersion  three-part version, defaults below
    WheelPath       path to the built maverick-agent wheel (required)
-->
<?ifndef ProductVersion ?>
  <?define ProductVersion = "0.1.6" ?>
<?endif?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!--
    UpgradeCode is the product family identity: it must NEVER change across
    releases or MajorUpgrade stops detecting installed versions and users
    end up with side-by-side installs. test_wxs.py pins this exact value.
  -->
  <Package
      Name="Maverick CLI"
      Manufacturer="cdayAI"
      Version="$(var.ProductVersion)"
      UpgradeCode="9E2B7C41-6A8D-4F3B-8E5A-2C90D17B4F6E"
      Language="1033"
      Scope="perUser"
      Compressed="yes">

    <MajorUpgrade
        AllowSameVersionUpgrades="no"
        DowngradeErrorMessage="A newer version of Maverick CLI is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- Per-user layout: %LOCALAPPDATA%\Programs\Maverick\{bin,wheels} -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="Maverick">
          <Directory Id="BINFOLDER" Name="bin" />
          <Directory Id="WHEELSFOLDER" Name="wheels" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <!--
      Per-user components keep an HKCU registry value as KeyPath (files under
      the user profile are not stable keypaths; this is the documented WiX
      pattern for perUser packages).
    -->
    <ComponentGroup Id="CliComponents">

      <Component Id="LauncherCmd" Directory="BINFOLDER">
        <File Id="MaverickCmd" Name="maverick.cmd" Source="maverick.cmd" />
        <RegistryValue Root="HKCU" Key="Software\Maverick\CLI"
                       Name="launcher" Type="integer" Value="1" KeyPath="yes" />
      </Component>

      <!--
        The wheel is renamed to a stable name inside the MSI so maverick.cmd
        can find it without globbing. WheelPath comes from build.ps1.
      -->
      <Component Id="BundledWheel" Directory="WHEELSFOLDER">
        <File Id="MaverickWheel" Name="maverick_agent.whl" Source="$(var.WheelPath)" />
        <RegistryValue Root="HKCU" Key="Software\Maverick\CLI"
                       Name="wheel" Type="string" Value="$(var.ProductVersion)" KeyPath="yes" />
      </Component>

      <!--
        Append bin\ to the USER PATH (System="no" - perUser install never
        touches the machine PATH). Part="last" appends instead of clobbering;
        the entry is removed on uninstall (Permanent="no").
      -->
      <Component Id="PathEnvironment" Directory="BINFOLDER">
        <Environment Id="UserPath" Name="PATH" Value="[BINFOLDER]"
                     Part="last" Action="set" Permanent="no" System="no" />
        <RegistryValue Root="HKCU" Key="Software\Maverick\CLI"
                       Name="path" Type="integer" Value="1" KeyPath="yes" />
      </Component>

    </ComponentGroup>

    <Feature Id="Cli" Title="Maverick CLI" Level="1">
      <ComponentGroupRef Id="CliComponents" />
    </Feature>

  </Package>
</Wix>
